{
  "name": "@ecss/ecss",
  "version": "0.1.0",
  "description": "ECSS (Extended CSS) — a language that extends CSS with three constructs for declarative component state management directly in stylesheets.",
  "keywords": [
    "css",
    "docs",
    "documentation",
    "ecss"
  ],
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.1.6",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.3"
  },
  "lint-staged": {
    "**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "**/*.json": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": "^10"
  },
  "packageManager": "pnpm@10.7.1"
}
